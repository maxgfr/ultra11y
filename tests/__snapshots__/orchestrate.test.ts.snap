exports[`orchestrate â€” contracts & runbook > golden shape (paths normalized) > RUNBOOK.md 1`] = `
"# ultra11y â€” sequential RUNBOOK (eco / no-subagent fallback)

Run: \`<RUN>\` Â· Engine: \`node <ENGINE>\`

Generated by \`ultra11y orchestrate\` from the CURRENT run state. This sequential path is
correctness-identical to the multi-agent workflows â€” same worklists, same contracts, same
fail-closed gates; only wall-clock differs. Fan-out is an optimization, not a requirement.

## Phase status

| Phase | Worklist | Status | Produce it with |
|---|---|---|---|
| adjudicate | \`<RUN>/ADJUDICATE.todo.json\` | ready (4 item(s)) | \`node <ENGINE> verify --manual --in <RUN>/audit-latest.json --out <RUN>\` |
| verify-report | \`<RUN>/VERIFY.todo.json\` | ready (2 item(s)) | \`node <ENGINE> verify --report <report.md> --out <RUN>\` |

## The loop (play every role yourself, one item at a time)

1. **Audit** (if not done): \`node <ENGINE> audit "<globs>" --graph --out <RUN>\` â†’ \`<RUN>/audit-latest.json\`.
2. **Adjudicate the residual criteria** â€” \`node <ENGINE> verify --manual --in <RUN>/audit-latest.json --out <RUN>\` writes \`<RUN>/ADJUDICATE.todo.json\`. For EVERY item, apply \`<RUN>/orchestration/agents/adjudicator.md\` yourself (read the evidence, rule C/NC/NA/manual, fill the required justification/findings/reason IN the todo file). Then fold, fail-closed: \`node <ENGINE> verify --apply <RUN>/ADJUDICATE.todo.json --in <RUN>/audit-latest.json --out <RUN>\`.
3. **Report**: \`node <ENGINE> report --in <RUN>/audit-latest.json --out <RUN>\`.
4. **Verify the report's claims** â€” \`node <ENGINE> verify --report <the report .md> --out <RUN>\` writes \`<RUN>/VERIFY.todo.json\`. For EVERY entry, apply \`<RUN>/orchestration/agents/refuter.md\` yourself (open file:line, verdict supported/partial/refuted/unsupported + note IN the todo file). Then: \`node <ENGINE> verify --apply <RUN>/VERIFY.todo.json --report <the report .md>\`.
5. **Gate**: \`node <ENGINE> check --report <the report .md> --semantic\` must exit 0 before presenting anything.
6. **Fix & re-audit**: \`node <ENGINE> fix <globs> --write --iterate\`, hand-apply the judgment fixes, then loop from step 1 until the gate stays green.

With subagents available, prefer the emitted workflows instead: \`orchestrate --run <RUN> --phase <p>\` then \`Workflow({ scriptPath: "<RUN>/orchestration/<p>.workflow.mjs" })\` â€” you stay the sole writer either way.
"
`;

exports[`orchestrate â€” contracts & runbook > golden shape (paths normalized) > adjudicate.workflow.mjs 1`] = `
"export const meta = {"name":"ultra11y-adjudicate","description":"Adjudicate the 4 residual judgment criterion(ia) of an ultra11y audit (fan-out, fail-closed fold)","phases":[{"title":"Adjudicate"}]}

// NOT a plain Node script: launch via the Workflow tool â€” Workflow({ scriptPath: "<RUN>/orchestration/adjudicate.workflow.mjs" }).
// Emitted by \`ultra11y orchestrate\` from the CURRENT worklist. The worklist is the source
// of truth: if it changes, re-run \`orchestrate --phase adjudicate\` before launching.

// Constants for THIS run (injected at emit time; no Date.now/Math.random in this harness).
const RUN = "<RUN>"
const ENGINE = "<ENGINE>"
const WORKLIST = "<RUN>/ADJUDICATE.todo.json"
const AGENTS = RUN + '/orchestration/agents'
const BATCHES = [["1.1.1","1.2.2","1.3.3","1.4.4"]]
const SCHEMA = {"type":"object","required":["verdicts"],"properties":{"verdicts":{"type":"array","items":{"type":"object","required":["criteriaId","verdict"],"properties":{"criteriaId":{"type":"string"},"verdict":{"enum":["C","NC","NA","manual"]},"justification":{"type":"string","description":"REQUIRED for C and NA"},"reason":{"type":["string","null"],"enum":["needs-rendered-dom","undecidable",null],"description":"REQUIRED for a still-manual verdict"},"findings":{"type":"array","description":"REQUIRED (>=1, groundable) for NC","items":{"type":"object","required":["file","line","message"],"properties":{"file":{"type":"string"},"line":{"type":"integer"},"selector":{"type":"string"},"message":{"type":"string"},"snippet":{"type":"string"},"severity":{"enum":["bloquant","majeur","mineur"]}}}}}}}}}

function contract(name, extra) {
  return 'Read and follow the dispatch contract at ' + AGENTS + '/' + name + '.md VERBATIM.\\n'
    + 'Constants: RUN=' + RUN + '  ENGINE=' + ENGINE + '  WORKLIST=' + WORKLIST + '.\\n'
    + 'Invoke the engine only by its ABSOLUTE path: node ' + ENGINE + ' <cmd> â€” read-only commands only.'
    + (extra ? '\\n' + extra : '')
}

log('ultra11y adjudicate: ' + "4" + ' item(s) across ' + BATCHES.length + ' agent(s)')

phase("Adjudicate")
const results = await pipeline(BATCHES, (batch, _item, i) =>
  agent(contract('adjudicator', 'ITEMS=' + batch.join(',')), { label: 'adjudicate:' + (i + 1), phase: "Adjudicate", agentType: 'general-purpose', schema: SCHEMA }))

// One-writer rule: this workflow only COLLECTS verdict fragments. The main agent folds
// them into WORKLIST (fill each item's fields from the matching fragment), then runs:
//   node <ENGINE> verify --apply <RUN>/ADJUDICATE.todo.json --in <RUN>/audit-latest.json --out <RUN>
return { phase: "adjudicate", worklist: WORKLIST, results: results.filter(Boolean) }
"
`;

exports[`orchestrate â€” contracts & runbook > golden shape (paths normalized) > refuter.md 1`] = `
"# Contract: refuter

You are an adversarial skeptic verifying the non-conformities of an ultra11y report. Your job is to try to REFUTE each claim: assume it is wrong until the source proves it.

Worklist: \`<RUN>/VERIFY.todo.json\` (a JSON array; each entry has \`n\`, \`criteriaId\`, \`file\`, \`line\`, \`selector\`, \`claim\`). Handle ONLY the entries whose \`n\` is named in your prompt (\`ITEMS=<n,â€¦>\`).

For EACH of your entries:

1. Open \`file\` at \`line\` and read the cited element (\`selector\`) in its real context.
2. Judge the claim against the source:
   - \`supported\` â€” the cited code violates the criterion exactly as claimed.
   - \`partial\` â€” a real issue, but the claim overstates it (wrong element, wrong scope, exaggerated count).
   - \`unsupported\` â€” the source does not establish the claim.
   - \`refuted\` â€” the source contradicts the claim.
   When unsure, choose the HARSHER verdict â€” a false pass is worse than a false fail.
3. \`note\` is REQUIRED â€” one line grounded in what you read (quote or paraphrase the decisive code).

Return (structured output): \`{ "verdicts": [{ "n", "verdict", "note" }] }\` â€” your ITEMS only.

## Return, don't write

Return ONLY the structured output specified above. Do NOT write, edit, or delete any file; do NOT run any engine command that writes (\`verify --apply\`, \`fix --write\`, \`audit --out\`, \`init\`). The orchestrator is the sole writer â€” it folds your verdicts into the worklist itself and runs the apply gate. Exception: if a justification is prose too large to return, write ONLY to \`<RUN>/orchestration/out/<role>-<batch>.md\` (a file namespaced to you alone) and return its path.
"
`;
