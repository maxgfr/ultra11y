{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to this project are documented here, generated automatically from the Conventional Commits by semantic-release."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/sync-version.mjs ${nextRelease.version} && pnpm run build && pnpm pack"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "src/types.ts",
          "skills/ultra11y/SKILL.md",
          "CHANGELOG.md",
          "scripts/ultra11y.mjs",
          "skills/ultra11y/scripts/ultra11y.mjs"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [{ "path": "*.tgz", "label": "npm tarball (ultra11y-${nextRelease.version}.tgz)" }]
      }
    ]
  ]
}
